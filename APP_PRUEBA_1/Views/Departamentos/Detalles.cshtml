@model APP_PRUEBA_1.Models.Departamento

@if (TempData["Errores"] != null)
{
    var errores = TempData["Errores"].ToString().Split("|");

    <div class="alert alert-danger">
        <ul>
            @foreach (var error in errores)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<h2 class="text-center mb-3">Detalles</h2>

<div class="d-flex flex-column justify-content-center align-items-center">
    <div class="card" style="max-width: 320px;">
        <div class="card-body">
            <div class="mb-2">
                <small class="text-muted">Identificador</small>
                <div class="fw-semibold">@Model.IdDepartamento</div>
            </div>
            <div>
                <small class="text-muted">Nombre</small>
                <div class="fs-5 fw-bold">@Model.Nombre</div>
            </div>
            <div>
                <small class="text-muted">Nombre</small>
                <div class="fs-5 fw-bold">@Model.Ubicacion</div>
            </div>
        </div>
    </div>
</div>