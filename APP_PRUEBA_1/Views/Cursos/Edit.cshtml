@model APP_PRUEBA_1.Models.Curso

@if (TempData["Errores"] != null)
{
    var errores = TempData["Errores"].ToString().Split("|");

    <div class="alert alert-danger">
        <ul>
            @foreach (var error in errores)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@if (TempData["Exito"] is string exito)
{
    <div class="alert alert-success">
        <ul>
            @exito
        </ul>
    </div>
}

<h2 class="text-center mb-3">Editar Curso</h2>

<div class="container d-flex justify-content-center align-items-center">

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="IdCurso" />

        <div class="mb-3">
            <label>Nombre del Curso</label>

            <input asp-for="NombreCurso"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label>Horas</label>

            <input asp-for="Horas"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label>Fecha Inicio</label>

            <input asp-for="FechaInicio"
                   type="date"
                   class="form-control" />
        </div>

        <div asp-validation-summary="All"
             class="text-danger">
        </div>

        <button type="submit"
                class="btn btn-primary">

            Guardar
        </button>

        <a asp-action="GetCursos"
           class="btn btn-secondary">

            Volver
        </a>

    </form>
</div>